// Render budget
const budgetEl=document.getElementById('budget');
budgetItems.forEach((b,i)=>{
  budgetEl.innerHTML+=`
    <div class="b-row">
      <div style="flex:1"><div style="font-size:12px;font-weight:600">${b.item}</div>${b.sub?`<div style="font-size:10px;color:#999">${b.sub}</div>`:''}</div>
