    {t:"09:00",d:"朝食ビュッフェをのんびり",i:"朝"},{t:"11:00",d:"プールサイド or ビーチでぼーっとする",i:"海"},{t:"14:00",d:"マタニティOKのスパ or カフェタイム",i:"癒"},{t:"17:30",d:"サンセット鑑賞",i:"夕"},{t:"19:00",d:"ディナー (ホテル or 恩納村)",i:"乾"}]},
