    </div>`;
});

// Toggle
function toggleDay(n){
  const el=document.getElementById('day'+n);
  const arrow=document.getElementById('arrow'+n);
  if(el.style.maxHeight&&el.style.maxHeight!=='0px'){
    el.style.maxHeight='0px';el.style.overflow='hidden';arrow.style.transform='rotate(0)';
  }else{
    el.style.maxHeight=el.scrollHeight+'px';el.style.overflow='visible';arrow.style.transform='rotate(180deg)';
  }
}
