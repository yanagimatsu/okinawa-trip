.b-row:last-child{border-bottom:none}
.day-toggle{cursor:pointer;user-select:none}
.day-content{overflow:hidden;transition:max-height .3s ease}
@keyframes dashAnim{to{stroke-dashoffset:-20}}
.dash-anim{animation:dashAnim 1.2s linear infinite}
