<script>
const days=[
  {num:1,date:"4/20 (月)",title:"午前着! 国際通り食べ歩き",color:"#FF7F7F",lc:"#FFE4E1",hotel:"那覇泊",ht:"naha",route:"羽田 -> 那覇空港 -> レンタカー -> 国際通り",items:[
    {t:"07:20",d:"羽田発 JAL903",i:"飛"},{t:"10:05",d:"那覇空港着",i:"着"},{t:"10:30",d:"送迎バスでレンタカー営業所 -> 出発",i:"車"},{t:"11:30",d:"国際通りへ! ポーたまでスパムおにぎり",i:"米"},{t:"12:30",d:"シーサー作り体験 (国際通り近く)",i:"獅"},{t:"14:30",d:"壺屋やちむん通りでお揃い器探し",i:"器"},{t:"15:30",d:"第一牧志公設市場あたりで食べ歩き",i:"食"},{t:"17:00",d:"ホテルで少し休憩",i:"休"},{t:"19:00",d:"栄町の居酒屋はしご",i:"酒"}]},
