.tl-d{font-size:13px;font-weight:500;margin-top:1px}
.h-row{display:flex;gap:8px;margin-bottom:6px;font-size:13px;align-items:baseline}
.h-day{font-weight:700;font-size:12px;flex-shrink:0;width:52px}
